{
  "name": "@birthub/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client.js",
    "./repositories": "./dist/repositories/index.js"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "prebuild": "pnpm --filter @birthub/config build && pnpm --filter @birthub/logger build && pnpm run db:generate",
    "pretypecheck": "pnpm --filter @birthub/config build && pnpm --filter @birthub/logger build",
    "build": "tsc -b tsconfig.json --force",
    "db:bootstrap:ci": "node --import tsx scripts/bootstrap-ci.ts",
    "db:generate": "node scripts/prisma-runtime-compat.mjs && prisma generate --schema prisma/schema.prisma",
    "db:migrate:deploy": "node --import tsx scripts/migrate-deploy-safe.ts",
    "db:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma --name cycle2_multitenancy",
    "db:reset": "prisma migrate reset --schema prisma/schema.prisma --force",
    "db:seed": "prisma db seed --schema prisma/schema.prisma",
    "db:seed:destructive": "node --import tsx prisma/seed.ts --profile=destructive --mode=destructive",
    "db:seed:safe": "node --import tsx prisma/seed.ts --profile=safe",
    "lint": "eslint .",
    "test": "pnpm run test:unit",
    "test:unit": "node --import tsx --test test/access-control.repo.test.ts test/base.repo.test.ts test/client.test.ts test/cross-tenant-access.error.test.ts test/database-availability.test.ts test/database-script-pipelines.test.ts test/engagement.test.ts test/exceeded-quota.error.test.ts test/index.test.ts test/prisma-query-timeout.error.test.ts test/prisma-schema.test.ts test/query-budget.test.ts test/schema-drift-environment.test.ts test/script-runtime.test.ts test/seed-runtime.test.ts test/tenant-required.error.test.ts test/tenant-scope.test.ts test/user-repository.test.ts",
    "test:isolation": "pnpm --filter @birthub/config build && pnpm --filter @birthub/logger build && pnpm run db:generate && node --import tsx --test test/migration.test.ts test/rls.test.ts test/maternal-domain.rls.test.ts",
    "typecheck": "tsc -b tsconfig.typecheck.json",
    "db:check:all": "node --import tsx scripts/post-migration-checklist.ts",
    "db:check:drift": "node --import tsx scripts/check-schema-drift.ts",
    "db:check:fk": "node --import tsx scripts/check-fk-indexes.ts",
    "db:check:governance": "node --import tsx scripts/check-migration-governance.ts",
    "db:check:joins": "node --import tsx scripts/check-raw-query-joins.ts",
    "db:check:performance": "node --import tsx scripts/analyze-performance.ts",
    "db:check:ri": "node --import tsx scripts/check-referential-integrity.ts",
    "db:check:tenancy": "node --import tsx scripts/check-tenancy-controls.ts",
    "db:compare:envs": "node --import tsx scripts/compare-migration-state.ts",
    "db:seed:ci": "node --import tsx prisma/seed.ts --profile=ci",
    "db:seed:smoke": "node --import tsx prisma/seed.ts --profile=smoke",
    "db:seed:staging": "node --import tsx prisma/seed.ts --profile=staging",
    "db:validate:pr": "node --import tsx scripts/validate-migrations-on-test-db.ts",
    "db:provision:app-role": "node --import tsx scripts/provision-rls-runtime-role.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@birthub/config": "workspace:^",
    "@birthub/logger": "workspace:^",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "6.19.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prisma": "6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest-mock-extended": "^4.0.0"
  },
  "files": [
    "dist"
  ]
}
