{
  "name": "@birthub/workflows-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./nextjs": "./dist/nextjs.js"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json --force",
    "lint": "eslint .",
    "lint:strict": "eslint . --config eslint.config.mjs --max-warnings=0",
    "test": "sh -c 'files=$(find tests -name \"*.test.ts\" -print 2>/dev/null); if [ -n \"$files\" ]; then node --import tsx --test $files; else echo \"No tests found\"; fi'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@birthub/logger": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ]
}
