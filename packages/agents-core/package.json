{
  "name": "@birthub/agents-core",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b tsconfig.json --force",
    "test": "sh -c 'files=$(find src -name \"*.test.ts\" -print); if [ -n \"$files\" ]; then node --import tsx --test $files; else echo \"No tests found\"; fi'",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc --out docs src/index.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./tools": "./dist/tools/index.js",
    "./policy": "./dist/policy/engine.js",
    "./manifest": "./dist/manifest/index.js",
    "./runtime": "./dist/runtime/index.js",
    "./skills": "./dist/skills/index.js"
  },
  "files": [
    "dist"
  ]
}
