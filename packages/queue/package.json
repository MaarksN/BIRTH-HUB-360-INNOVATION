{
  "name": "@birthub/queue",
  "version": "0.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@birthub/logger": "workspace:*",
    "@birthub/shared-types": "workspace:*",
    "bullmq": "^5.73.0",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test:load": "tsx load-test/bullmq-load-test.ts",
    "schedule:crons": "tsx scripts/schedule-recurring-jobs.ts",
    "test": "sh -c 'files=$(find tests -name \"*.test.ts\" -print 2>/dev/null); if [ -n \"$files\" ]; then node --import tsx --test $files; else echo \"No tests found\"; fi'",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "private": true,
  "files": [
    "dist"
  ]
}
