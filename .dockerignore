yarn-debug.log*
pnpm-debug.log*

# IDE
.vscode
.idea
*.swp
*.swo
.DS_Store
*.sublime-project
*.sublime-workspace

# Environment
.env.local
.env.*.local

# Documentation
docs
*.md
README.md
ARCHITECTURE.md
CONTRIBUTING.md
IMPROVEMENTS.md
TECHNICAL_DEBT_REPORT.md

# Test files
test
tests
*.test.ts
*.spec.ts
__tests__

# GitHub workflows
.github

# Kubernetes
k8s

# Temporary
tmp
temp
.cache
artifacts

# CI/CD
.circleci
.gitlab-ci.yml
Jenkinsfile
