{
  "name": "birthub-360",
  "version": "1.0.0",
  "private": true,
  "description": "Repositório canônico da plataforma SaaS BirthHub 360.",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": "9.15.9"
  },
  "type": "commonjs",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@birthub/web --filter=@birthub/api --filter=@birthub/worker --parallel",
    "lint": "turbo run lint",
    "security:licenses": "node ./scripts/ci/check-dependency-licenses.mjs",
    "security:sarif:gate": "node ./scripts/ci/assert-sarif-threshold.mjs",
    "setup:dev": "node scripts/setup-dev.js",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --concurrency=1",
    "db:generate": "pnpm --filter @birthub/database db:generate",
    "db:migrate:deploy": "pnpm --filter @birthub/database db:migrate:deploy",
    "db:check:all": "pnpm --filter @birthub/database db:check:all",
    "db:check:drift": "pnpm --filter @birthub/database db:check:drift",
    "db:seed": "pnpm --filter @birthub/database db:seed",
    "packs:validate": "pnpm --filter @birthub/agent-packs validate",
    "packs:test": "pnpm --filter @birthub/agent-packs test",
    "packs:docs": "pnpm --filter @birthub/agent-packs docs",
    "packs:qa": "pnpm --filter @birthub/agent-packs qa",
    "start:web": "pnpm --filter @birthub/web start",
    "start:api": "pnpm --filter @birthub/api start",
    "start:worker": "pnpm --filter @birthub/worker start",
    "clean": "rimraf --glob .turbo \"apps/*/.turbo\" \"apps/*/dist\" \"apps/web/.next\" \"packages/*/.turbo\" \"packages/*/dist\" \"packages/*/*.tsbuildinfo\" \"packages/config/src/*.js\" \"packages/config/src/*.d.ts\" \"packages/config/src/*.d.ts.map\" \"packages/logger/src/*.js\" \"packages/logger/src/*.d.ts\" \"packages/logger/src/*.d.ts.map\"",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@birthub/agents-core": "workspace:*",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@stryker-mutator/core": "^9.6.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.58.1",
    "c8": "^10.1.3",
    "eslint": "^10.0.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "knip": "^5.64.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "prisma": "6.19.3",
    "rimraf": "^6.1.2",
    "tsx": "^4.21.0",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@types/opossum": "^8.1.9",
    "lru-cache": "^11.3.3",
    "opossum": "^9.0.0"
  },
  "pnpm": {
    "overrides": {
      "defu": ">=6.1.5",
      "effect": ">=3.20.0",
      "eslint-import-resolver-typescript>unrs-resolver": "npm:empty-npm-package@1.0.0",
      "fast-xml-parser": ">=5.5.7",
      "flatted": ">=3.4.2",
      "next": "16.2.4",
      "path-to-regexp": "8.4.0",
      "picomatch": "4.0.4",
      "typescript": "5.9.3"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
