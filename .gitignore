# Monorepo hygiene at the repository root.
/node_modules/
/dist/
/build/
/coverage/
/.turbo/
/.next/
/artifacts/
/tmp/
/temp/

# Environment files (secrets must not be committed)
.env
.env.*
!.env.example
!.env.vps.example
.env.local
.env.*.local

# Workspace-local generated content inside apps/ and packages/.
/apps/**/node_modules/
/apps/**/dist/
/apps/**/build/
/apps/**/coverage/
/apps/**/.turbo/
/apps/**/.next/
/apps/**/artifacts/
/apps/**/tmp/
/apps/**/temp/

/packages/**/node_modules/
/packages/**/dist/
/packages/**/build/
/packages/**/coverage/
/packages/**/.turbo/
/packages/**/.next/
/packages/**/artifacts/
/packages/**/tmp/
/packages/**/temp/

# Build metadata and transient logs.
*.tsbuildinfo
*.log

# Package source trees should contain TypeScript sources only; package builds emit to dist/.
/packages/config/src/*.js
/packages/config/src/*.d.ts
/packages/config/src/*.d.ts.map
/packages/logger/src/*.js
/packages/logger/src/*.d.ts
/packages/logger/src/*.d.ts.map
