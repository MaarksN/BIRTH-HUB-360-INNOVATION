{
  "name": "@birthub/webhook-receiver",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/apps/webhook-receiver/src/index.js",
  "types": "./dist/apps/webhook-receiver/src/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/apps/webhook-receiver/src/index.js",
    "test": "sh -c 'files=$(find src -name \"*.test.ts\" -print); if [ -n \"$files\" ]; then node --import tsx --test $files; else echo \"No tests found\"; fi'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@birthub/config": "workspace:*",
    "@birthub/integrations": "workspace:*",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ]
}
